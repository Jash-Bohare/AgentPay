# Server
PORT=3001

# Casper network
CASPER_NETWORK=casper-test
CASPER_NODE_ADDRESS=https://node.testnet.casper.network/rpc
CSPR_CLOUD_API_KEY=

# Contract addresses (filled in after Phase 1 deployment)
REGISTRY_CONTRACT_HASH=
REPUTATION_CONTRACT_HASH=
PAYMENT_CONTRACT_HASH=

# Facilitator wallet (co-signs/initiates settlement transfers)
FACILITATOR_PRIVATE_KEY_PATH=

# Test provider wallet, used by POST /provider/register to sign registrations.
# Hackathon simplification: in production, providers sign register_listing
# client-side via their own wallet extension; the backend never holds this key.
PROVIDER_PRIVATE_KEY_PATH=

# PostgreSQL (Supabase)
DATABASE_URL=

# Redis (Upstash)
REDIS_URL=

# Treasury wallet (receives protocol fee)
TREASURY_WALLET=
